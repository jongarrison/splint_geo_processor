# Platform: macOS toolchain paths -- committed to git
RHINO_CLI=/Applications/Rhino 8.app/
RHINOCODE_CLI=/Applications/Rhino 8.app/Contents/Resources/bin/rhinocode
BAMBU_CLI=/Applications/BambuStudio.app/Contents/MacOS/BambuStudio

# Startup behavior parity with Windows defaults
RHINO_START_SCRIPT_SERVER_ON_LAUNCH=true
RHINO_STARTUP_COMMAND=StartScriptServer
RHINO_STARTUP_FAIL_FAST_UNHEALTHY_ATTEMPTS=0
RHINO_EXECUTION_PROBE_WAIT_MS=8000
